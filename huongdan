// HomeController.php dòng 14-45
public function index(): void {
    Auth::requireLogin();
    $userId = Auth::id();
    $role   = Auth::role();

    if ($role === 'ADMIN') {
        // Lấy số liệu thống kê tổng quan
        $data['totalEmployees'] = $userModel->countAll();
            // SELECT COUNT(*) FROM users WHERE deleted_at IS NULL AND status != 'LOCKED'

        $data['pendingLeaves']  = $leaveModel->countAll('PENDING');
            // SELECT COUNT(*) FROM leave_requests WHERE status = 'PENDING'

