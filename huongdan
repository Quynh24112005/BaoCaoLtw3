// EmployeeController::delete() dòng 147-173
public function delete(): void {
    $id = (int)$this->post('id');

    // Bảo vệ: không tự xóa chính mình
    if ($id === Auth::id()) {
        Session::flash('error', 'Bạn không thể tự xóa tài khoản của chính mình.');
        redirect('/employees');
        return;
    }

    $employee = $this->userModel->findById($id);
    if (!$employee) abort(404);

    $this->userModel->softDelete($id);
    // UPDATE users SET deleted_at = NOW() WHERE id = ?
    // Không xóa khỏi DB thật — giữ lại lịch sử

    $this->sysModel->writeAudit(['action' => 'DELETE_EMPLOYEE', ...]);

    Session::flash('success', "Đã xóa nhân viên {$employee['full_name']} thành công.");
    redirect('/employees');
}
```

